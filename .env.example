# LLM provider
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace_with_your_api_key
LLM_MODEL=gpt-4.1-mini

# Optional judge / reviewer model
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_API_KEY=replace_with_your_api_key
JUDGE_MODEL=gpt-4.1

# GitHub integration
GITHUB_TOKEN=replace_with_your_github_token
GITHUB_DEFAULT_OWNER=oowpc

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
OUTPUTS_DIR=outputs
DATABASE_PATH=storage/agent_orchestrator.sqlite3

# Safety settings
REQUIRE_CONFIRMATION_FOR_DANGEROUS_ACTIONS=true
ENABLE_CODE_EXECUTION=false
ENABLE_GITHUB_WRITE=false
ENABLE_DOCKER_SANDBOX=false
